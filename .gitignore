# ============================================
# R / RStudio
# ============================================

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp
.Ruserdata

# R environment variables
.Renviron

# RStudio files
.Rproj.user/
.Rproj

# Example code in package build process
*-Ex.R

# Output files from R CMD build / check
/*.tar.gz
/*.Rcheck/

# Knitr / R Markdown cache and temporary files
*_cache/
/cache/
*.utf8.md
*.knit.md

# Produced vignettes
vignettes/*.html
vignettes/*.pdf

# pkgdown site
docs/

# Translation temp files
po/*~

# RStudio Connect deployment folder
rsconnect/

# OAuth2 token (https://github.com/hadley/httr/releases/tag/v0.3)
.httr-oauth

# ============================================
# Python / Atajos de entorno virtual
# ============================================

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
venv/
ENV/
env/
.venv

# Python notebooks (si quieres limpiar outputs antes de commit)
# .ipynb_checkpoints/

# ============================================
# Archivos de texto y logs temporales
# ============================================

*.log
*.out
#*.txt

# Archivo de salida de tu tesis (si es autogenerado)
output_final.txt

# ============================================
# Archivos de Office / Documentación compilada
# ============================================

*.doc
*.docx
*.odt
#*.html
*.pdf
*.htm

# Carpetas de archivos auxiliares al renderizar HTML/PDF
*_files/

# ============================================
# Imágenes generadas por R / Python (plots)
# ============================================

*.png
*.svg
*.jpg
*.jpeg
*.bmp
*.tiff

# ============================================
# Bases de datos y datos crudos
# ============================================

# Datos en Excel / CSV (opcional: comentar si son pequeños)
*.xlsx
*.xls
*.csv

# Bases de datos
*.db
*.sqlite
*.sqlite3

# ============================================
# Archivos de sistema y respaldos
# ============================================

# Editor backups
*~
*.swp
*.bak
*.tmp

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Otros archivos generados o específicos de tu proyecto
# ============================================

# Si usas Quarto, Jupyter, o LaTeX
*.tex
*.aux
*.bbl
*.blg

# Scripts o archivos temporales del sistema
# (ejemplo: .Rhistory ya está arriba, .RData también)
